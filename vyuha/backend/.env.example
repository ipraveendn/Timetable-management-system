# ============================================
# VYUHA Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control!

# Environment (development|staging|production)
ENVIRONMENT=development

# Debug mode (true|false) - NEVER use true in production!
DEBUG=true

# Log level (DEBUG|INFO|WARNING|ERROR)
LOG_LEVEL=DEBUG

# Application URL
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ============================================
# Database Configuration (Supabase)
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-with-admin-privileges
SUPABASE_KEY=your-supabase-anon-key-for-frontend-use

# ============================================
# JWT Authentication
# ============================================
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-64-character-hex-string-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=30

# ============================================
# Email/SMTP Configuration
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=noreply@institution.edu
SMTP_FROM_NAME=VYUHA Academy

# ============================================
# Security Configuration
# ============================================
# Comma-separated list of allowed origins (no spaces)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
SESSION_TIMEOUT_MINUTES=30

# ============================================
# Optional External APIs (only if needed)
# ============================================
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GROQ_API_KEY=gsk_...
# SENDGRID_API_KEY=SG...
# STRIPE_SECRET_KEY=sk_live_...
